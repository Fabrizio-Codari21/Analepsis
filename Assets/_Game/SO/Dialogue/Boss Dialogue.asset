            Part2: 1202704735
            Part3: 4006691485
            Part4: 2818646251
          tag: 
    - rid: 5324356914828018092
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Wait, when you say West...]'
        nextNode:
          rid: 5324356914828018095
        m_conditions: []
        editorPosition: {x: 4072, y: -518}
    - rid: 5324356914828018093
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Don''t worry, I don''t mind.]'
        nextNode:
