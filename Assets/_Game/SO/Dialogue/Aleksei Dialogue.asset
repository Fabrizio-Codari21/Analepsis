  m_Script: {fileID: 11500000, guid: 86211e2fd74fb484598c1176279aee61, type: 3}
  m_Name: Aleksei Dialogue
  m_EditorClassIdentifier: 
  dialogueColor: {r: 0, g: 0, b: 0, a: 0}
  startingNode:
    dialogueText: Don't interrupt me please
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389271
    isRootNode: 1
    editorPosition: {x: 300, y: 200}
    guid:
      Part1: 1876034031
      Part2: 1266233403
      Part3: 588551583
      Part4: 305309663
    tag: 
  allNodes:
  - dialogueText: 
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses: []
    isRootNode: 1
    editorPosition: {x: 300, y: 200}
    guid:
      Part1: 1876034031
      Part2: 1266233403
      Part3: 588551583
      Part4: 305309663
    tag: 
  - dialogueText: 'No, wait!

      You aren''t really interrupting anything...

      I''m
      supposed to be working but I just can''t seem to concentrate right now!

      I''m
      perpetually surrounded by distractions!'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389273
    - rid: 6774952781063389274
    isRootNode: 0
    editorPosition: {x: 842, y: 200}
    guid:
      Part1: 121336126
      Part2: 1108950013
      Part3: 2249797309
      Part4: 2547815713
    tag: 
  - dialogueText: 'My magnum opus of course!

      I came to this hotel in the middle
      of nowhere to help me focus

      Art isn''t done in between parties and drugs,
      or so my acquaintances insisted before draggin me here with their constant
      negging...'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389276
    isRootNode: 0
    editorPosition: {x: 1685, y: 200}
    guid:
      Part1: 122495793
      Part2: 1107580802
      Part3: 2868873098
      Part4: 766361834
    tag: 
  - dialogueText: 'Honestly I don''t know why anyone would ever want to come here!

      There''s
      absolutely nothing to be found in the barren wasteland.

      Come to think
      of it, what are <b>you<\b> doing here?'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389282
    - rid: 6774952781063389283
    isRootNode: 0
    editorPosition: {x: 2719, y: 200}
    guid:
      Part1: 1638892124
      Part2: 1148913163
      Part3: 1816418959
      Part4: 2822193649
    tag: 
  - dialogueText: 'Oh yeah, I can''t catch a break from all the fame...

      It''s
      hard, you know? Everyone wanting to look at you, take pictures of you, interview
      you

      It''s always about you- I mean me. Honestly honey? I don''t know
      how I do it'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389279
    isRootNode: 0
    editorPosition: {x: 1684.9999, y: 431}
    guid:
      Part1: 4181029613
      Part2: 1275199733
      Part3: 2353852820
      Part4: 4211439072
    tag: 
  - dialogueText: 'What''s worse is I cannot for the life of me get rid of the paparazzis!
      Even here!

      I just heard that damn camera shutter. If I ever find them
      I have a word or two to say to whoever is taking pictures! at my! spiritual!
      retreat!'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 6774952781063389281
    isRootNode: 0
    editorPosition: {x: 2499, y: 431}
    guid:
      Part1: 1866444140
      Part2: 1318639581
      Part3: 3008323730
      Part4: 425362122
    tag: 
  - dialogueText: Oh, fun! I've always admired an inquisitive man
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 767062219271962627
    isRootNode: 0
    editorPosition: {x: 3526, y: 25}
    guid:
      Part1: 862484953
      Part2: 1290569314
      Part3: 1072531848
      Part4: 3471224199
    tag: 
  - dialogueText: It's all right darling, we all secrets
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 767062219271962626
    isRootNode: 0
    editorPosition: {x: 3526, y: 226}
    guid:
      Part1: 4112438073
      Part2: 1192836931
      Part3: 2316540604
      Part4: 2755046529
    tag: 
  - dialogueText: 'Well now that you mention it...

      I haven''t noticed anything!

      But
      I do have the feeling that someone is following me, probably one of my crazy
      fans'
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 767062219271962629
    isRootNode: 0
