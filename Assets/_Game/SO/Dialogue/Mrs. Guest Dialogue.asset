  startingNode:
    dialogueText: 'Well, hello there, darling. You seem like someone who likes a
      good chat.

      How about you sit down so we can talk about important stuff...?'
    characterEmotion: 1
    doesItProveAnything: 0
    responses:
    - rid: 5324356914828018101
    - rid: 5324356914828018102
