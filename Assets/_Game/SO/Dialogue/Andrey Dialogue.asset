      Part1: 3036664030
      Part2: 1257445403
      Part3: 1589302673
      Part4: 1385208169
    tag: 
  - dialogueText: Why though, you weren't even here during lunch
    characterEmotion: 0
    characterReaction: 0
    doesItProveAnything: 0
    isKey: 0
    responses:
    - rid: 767062219271962639
    isRootNode: 0
    editorPosition: {x: 1598, y: -385}
