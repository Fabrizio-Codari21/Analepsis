  startingNode:
    dialogueText: Hey there...
    characterEmotion: 1
    characterReaction: 1
    doesItProveAnything: 4
    isKey: 0
    responses:
    - rid: 6774952466358992965
    - rid: 6774952466358992967
    isRootNode: 1
