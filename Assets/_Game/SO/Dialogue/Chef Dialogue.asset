          Part4: 73563290
        tag: 
    - rid: 5324356914828018040
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[So she''s been <b>threatened</b>...]'
        nextNode:
          rid: -2
        m_conditions: []
        editorPosition: {x: 2028.0895, y: 566}
    - rid: 5324356914828018041
      type: {class: DialogueNodeCondition, ns: , asm: Assembly-CSharp}
      data:
        conditionName: 
        unlockIfTrue: 1
        targetDialogue: {fileID: 11400000, guid: 5e6d5ea638b02b4489ba789f296d81bb, type: 2}
        isTalkDialogueNode:
          dialogueText: 'Oh... nothing, it''s just... um... I was thinking about
            my family, who live in the West, and sometimes when I do that my old
            accent comes back.

            I shouldn''t be so self-conscious about
            it, but people can get very sensitive when it comes to those things.'
          characterEmotion: 0
          doesItProveAnything: 0
          responses:
          - rid: 5324356914828018063
          - rid: 5324356914828018064
          isRootNode: 0
          editorPosition: {x: 3217, y: -476}
          guid:
            Part1: 3971381098
            Part2: 1202704735
            Part3: 4006691485
            Part4: 2818646251
          tag: 
    - rid: 5324356914828018063
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Wait, when you say West...]'
        nextNode:
          rid: 5324356914828018066
        m_conditions: []
        editorPosition: {x: 4072, y: -518}
    - rid: 5324356914828018064
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Don''t worry, I don''t mind.]'
        nextNode:
          rid: 5324356914828018067
        m_conditions: []
        editorPosition: {x: 4072, y: -687}
    - rid: 5324356914828018066
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: ...n-no, i DON'T mean... you know... "that" West, I mean...
          um... Sorry, I have things to do.
        characterEmotion: 0
        doesItProveAnything: 0
        responses:
        - rid: 5324356914828018068
        isRootNode: 0
        editorPosition: {x: 4479, y: -518}
        guid:
          Part1: 2653160003
          Part2: 1118949611
          Part3: 3135390394
          Part4: 3955660051
        tag: 
    - rid: 5324356914828018067
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: 'After a war like that, it shocks me that anyone could still
          care about something so insignificant.

          All I want now is to
          be able to rest without anyone thinking I''m a menace... I mean... Excuse
          me, I have to go.'
        characterEmotion: 0
        doesItProveAnything: 0
        responses:
        - rid: 5324356914828018069
        isRootNode: 0
        editorPosition: {x: 4447, y: -735}
        guid:
          Part1: 3008374608
          Part2: 1171127585
          Part3: 2291297185
          Part4: 217656539
        tag: 
    - rid: 5324356914828018068
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Uh-oh, I think I screwed it.]'
        nextNode:
          rid: -2
        m_conditions: []
        editorPosition: {x: 5153, y: -536}
    - rid: 5324356914828018069
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Someone''s calling her a <b>menace</b>...]'
        nextNode:
          rid: -2
        m_conditions: []
        editorPosition: {x: 5269, y: -735}
