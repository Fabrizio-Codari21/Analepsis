    - rid: 8641241821780639980
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[Someone''s calling her a <b>menace</b>...]'
        nextNode:
          rid: -2
        dialogueTopic: 
        m_conditions: []
        alreadyDisplayed: 0
        editorPosition: {x: 5269, y: -735}
    - rid: 8641241821780639981
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: 'I... never said she was a foreigner. Don''t you dare put words
          in my mouth... I mean, I''d rather you abstained from spreading such misinformation.

          Any
          inconvenient you may have with her is something the two of you should deal
          with.'
        characterEmotion: 2
        characterReaction: 8
