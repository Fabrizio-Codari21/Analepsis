    - rid: 8641241821780639965
      type: {class: DialogueResponse, ns: , asm: Assembly-CSharp}
      data:
        responseText: '[What''s up with the maid?]'
        nextNode:
          rid: 8641241821780639968
        dialogueTopic: 
        m_conditions:
        - rid: 8641241821780639969
        alreadyDisplayed: 0
        editorPosition: {x: 961.99994, y: 491}
    - rid: 8641241821780639966
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "Oh... Nothing that you should worry about, really. \nIt's
          just... I seem to have lost the keys to my car. It's a fancy new model
          and I've barely had a chance to drive it yet.\nI doubt you're gonna find
          them around here, but if you find out something... please let me know."
        characterEmotion: 1
        characterReaction: 2
        doesItProveAnything: 0
        responses:
        - rid: 8641241821780639970
        isRootNode: 0
        editorPosition: {x: 1400.5004, y: 280.49997}
        guid:
          Part1: 1756710703
          Part2: 1229670118
          Part3: 834325127
          Part4: 1991192220
        tag: About keys
    - rid: 8641241821780639967
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: '...Well, if that''s the case, I should ask you to leave.

          However,
          it would be uncouth to let you go out there, with such a terrible storm
          going on.

          You may stay, but please, don''t go anywhere past
          this reception.'
        characterEmotion: 2
        characterReaction: 6
        doesItProveAnything: 0
        responses:
        - rid: 8641241821780639971
        isRootNode: 0
        editorPosition: {x: 1401, y: 49.449997}
        guid:
          Part1: 1703566582
          Part2: 1202352971
          Part3: 3294678954
          Part4: 865554740
        tag: 
    - rid: 8641241821780639968
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: 'Oh, please ignore her. She has the tendency to become... histerical...
          at the least convenient moments.

          She can make up stories, accuse
          people of unproper behaviour... I highly advice you remain from trusting
          her.'
        characterEmotion: 1
        characterReaction: 2
        doesItProveAnything: 0
        responses:
        - rid: 8641241821780639972
        isRootNode: 0
        editorPosition: {x: 1355.668, y: 509.25046}
        guid:
          Part1: 2547384374
          Part2: 1283484775
          Part3: 3713609364
          Part4: 931363781
        tag: 
    - rid: 8641241821780639969
      type: {class: DialogueNodeCondition, ns: , asm: Assembly-CSharp}
      data:
        conditionName: 
        unlockIfTrue: 1
        targetDialogue: {fileID: 11400000, guid: 5e6d5ea638b02b4489ba789f296d81bb, type: 2}
        isTalkDialogueNode:
          dialogueText: 'Oh... nothing, it''s just... um... I was thinking about
            my family, who live in the West, and sometimes when I do that my old
            accent comes back.

            I shouldn''t be so self-conscious about
            it, but people can get very sensitive when it comes to those things.'
          characterEmotion: 0
          characterReaction: 0
          doesItProveAnything: 0
          responses:
